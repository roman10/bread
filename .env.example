# Trading mode: "paper" or "live"
# BREAD_MODE=paper

# Alpaca paper trading credentials
ALPACA_PAPER_API_KEY=your-paper-api-key
ALPACA_PAPER_SECRET_KEY=your-paper-secret-key

# Alpaca live trading credentials (only required in live mode)
# ALPACA_LIVE_API_KEY=your-live-api-key
# ALPACA_LIVE_SECRET_KEY=your-live-secret-key

# Optional nicknames shown in status/run/dashboard alongside the Alpaca
# account number — useful when running multiple paper/live accounts.
# ALPACA_PAPER_NICKNAME=Main Paper
# ALPACA_LIVE_NICKNAME=Prod

# Alert URLs (configure in config/paper.yaml or config/live.yaml)
# Discord: discord://WEBHOOK_ID/WEBHOOK_TOKEN
# Get webhook URL from: Discord channel → Edit Channel → Integrations → Webhooks
